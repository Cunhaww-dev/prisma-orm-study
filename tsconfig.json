{
  "compilerOptions": {
    // "rootDir": "./src", comentado por conta do prisma.config.ts que está na raiz do projeto
    "outDir": "./dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2024",
    "lib": ["ES2024"],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "prisma.config.ts", "prisma"]
}
